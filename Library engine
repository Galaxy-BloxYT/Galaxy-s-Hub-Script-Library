local Library = {}

function Library:Init(title)
    -- ... [Mantém o Main e Sidebar] ...
    
    local TabContentContainer = Instance.new("Frame", Main)
    TabContentContainer.Position = UDim2.new(0, 130, 0, 10)
    TabContentContainer.Size = UDim2.new(1, -140, 1, -20)
    TabContentContainer.BackgroundTransparency = 1

    local Window = {}

    function Window:CreateTab(name)
        -- Botão na Sidebar
        local tabBtn = Instance.new("TextButton", Sidebar)
        tabBtn.Size = UDim2.new(0.9, 0, 0, 40)
        tabBtn.Text = name
        -- ... [Design do botão] ...

        -- O Frame que vai segurar os elementos dessa aba específica
        local tabFrame = Instance.new("ScrollingFrame", TabContentContainer)
        tabFrame.Size = UDim2.new(1, 0, 1, 0)
        tabFrame.BackgroundTransparency = 1
        tabFrame.Visible = false -- Começa invisível
        
        -- Lógica de trocar
        tabBtn.MouseButton1Click:Connect(function()
            -- Esconde todas as abas
            for _, child in pairs(TabContentContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then child.Visible = false end
            end
            -- Mostra apenas a atual
            tabFrame.Visible = true
        end)

        return tabFrame -- Retorna o frame para você adicionar botões dentro
    end

    return Window
end
