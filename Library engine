local Library = {}
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local function BuildUI(title)
    local ExistingUI = CoreGui:FindFirstChild("GalaxyLib")
    if ExistingUI then ExistingUI:Destroy() end
    getgenv().GalaxyLibRunning = true 

    local UI = Instance.new("ScreenGui", CoreGui); UI.Name = "GalaxyLib"; UI.ResetOnSpawn = false
    local Main = Instance.new("Frame", UI); Main.Size = UDim2.new(0, 500, 0, 300); Main.Position = UDim2.new(0.5, -250, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
    local MainStroke = Instance.new("UIStroke", Main); MainStroke.Color = Color3.new(1,1,1); MainStroke.Thickness = 2
    
    local TopBar = Instance.new("Frame", Main); TopBar.Size = UDim2.new(1, 0, 0, 40); TopBar.BackgroundTransparency = 1
    local Title = Instance.new("TextLabel", TopBar); Title.Size = UDim2.new(1, -100, 1, 0); Title.Position = UDim2.new(0, 10, 0, 0); Title.Text = title; Title.TextColor3 = Color3.new(1,1,1); Title.Font = Enum.Font.GothamBold; Title.BackgroundTransparency = 1; Title.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Botões de Controle
    local CloseBtn = Instance.new("TextButton", TopBar); CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -35, 0, 5); CloseBtn.Text = "X"; CloseBtn.BackgroundTransparency = 1; CloseBtn.TextColor3 = Color3.new(1,1,1)
    local MinBtn = Instance.new("TextButton", TopBar); MinBtn.Size = UDim2.new(0, 30, 0, 30); MinBtn.Position = UDim2.new(1, -70, 0, 5); MinBtn.Text = "-"; MinBtn.BackgroundTransparency = 1; MinBtn.TextColor3 = Color3.new(1,1,1)

    local TabContent = Instance.new("Frame", Main); TabContent.Size = UDim2.new(1, 0, 1, -40); TabContent.Position = UDim2.new(0, 0, 0, 40); TabContent.BackgroundTransparency = 1
    
    -- Draggable Suave (Mobile + PC)
    local dragging, dragInput, dragStart, startPos
    TopBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; dragStart = input.Position; startPos = Main.Position end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart; Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

    -- Minimizar/Fechar
    local min = false
    MinBtn.MouseButton1Click:Connect(function() min = not min; TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = min and UDim2.new(0, 500, 0, 40) or UDim2.new(0, 500, 0, 300)}):Play(); TabContent.Visible = not min end)
    CloseBtn.MouseButton1Click:Connect(function() for _,v in pairs(TabContent:GetChildren()) do if v:IsA("ScrollingFrame") then v:Destroy() end end; TabContent.Visible = false end)

    local Sidebar = Instance.new("Frame", TabContent); Sidebar.Size = UDim2.new(0, 130, 1, 0); Sidebar.BackgroundTransparency = 1
    local Content = Instance.new("Frame", TabContent); Content.Position = UDim2.new(0, 140, 0, 0); Content.Size = UDim2.new(1, -150, 1, 0); Content.BackgroundTransparency = 1
    
    local Window = {}
    function Window:CreateTab(name)
        local btn = Instance.new("TextButton", Sidebar); btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Text = name; btn.BackgroundColor3 = Color3.fromRGB(30,30,30); btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", btn); Instance.new("UIStroke", btn).Color = Color3.new(1,1,1)
        local TabFrame = Instance.new("ScrollingFrame", Content); TabFrame.Size = UDim2.new(1, 0, 1, 0); TabFrame.BackgroundTransparency = 1; TabFrame.Visible = false; TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y; Instance.new("UIListLayout", TabFrame).Padding = UDim.new(0, 10)
        btn.MouseButton1Click:Connect(function() for _,v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end; TabFrame.Visible = true end)
        
        local TabObj = {}
        function TabObj:AddToggle(t, cb) local s = false; local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 40); b.Text = t; b.TextColor3 = Color3.new(1,1,1); b.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", b); Instance.new("UIStroke", b).Color = Color3.new(1,1,1); b.MouseButton1Click:Connect(function() s = not s; b.BackgroundColor3 = s and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(30,30,30); cb(s) end) end
        function TabObj:AddDropdown(n, l, cb)
            local d = Instance.new("TextButton", TabFrame); d.Size = UDim2.new(0.9, 0, 0, 40); d.Text = n; d.TextColor3 = Color3.new(1,1,1); d.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", d); Instance.new("UIStroke", d).Color = Color3.new(1,1,1)
            local lh = Instance.new("ScrollingFrame", TabFrame); lh.Size = UDim2.new(0.9, 0, 0, 100); lh.BackgroundColor3 = Color3.fromRGB(20,20,20); lh.Visible = false; lh.ZIndex = 5; Instance.new("UIListLayout", lh); Instance.new("UICorner", lh)
            d.MouseButton1Click:Connect(function() lh.Visible = not lh.Visible end)
            for _, i in pairs(l) do local o = Instance.new("TextButton", lh); o.Size = UDim2.new(1, 0, 0, 30); o.Text = i; o.TextColor3 = Color3.new(1,1,1); o.BackgroundTransparency = 1; o.ZIndex = 6; o.MouseButton1Click:Connect(function() lh.Visible = false; d.Text = i; cb(i) end) end
        end
        return TabObj
    end
    return Window
end
Library.Construct = BuildUI
return Library
