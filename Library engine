local Library = {}
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

local function BuildUI(title)
    local ExistingUI = CoreGui:FindFirstChild("GalaxyLib")
    if ExistingUI then ExistingUI:Destroy() end
    
    local UI = Instance.new("ScreenGui", CoreGui); UI.Name = "GalaxyLib"; UI.ResetOnSpawn = false
    local NotifyHolder = Instance.new("Frame", UI); NotifyHolder.Size = UDim2.new(0, 260, 1, -20); NotifyHolder.Position = UDim2.new(1, -270, 0, 10); NotifyHolder.BackgroundTransparency = 1
    Instance.new("UIListLayout", NotifyHolder).Padding = UDim.new(0, 10)

    local Main = Instance.new("Frame", UI)
    Main.Size = UDim2.new(0, 500, 0, 300); Main.Position = UDim2.new(0.5, -250, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(30, 30, 30); Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", Main).Color = Color3.fromRGB(50, 50, 50)
    
    local TopBar = Instance.new("Frame", Main); TopBar.Size = UDim2.new(1, 0, 0, 40); TopBar.BackgroundTransparency = 1
    local Title = Instance.new("TextLabel", TopBar); Title.Name = "Title"; Title.Size = UDim2.new(1, -80, 1, 0); Title.Position = UDim2.new(0, 10, 0, 0); Title.Text = title; Title.TextColor3 = Color3.new(1,1,1); Title.Font = Enum.Font.GothamBold; Title.BackgroundTransparency = 1; Title.TextXAlignment = Enum.TextXAlignment.Left
    
    local CloseBtn = Instance.new("TextButton", TopBar); CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -35, 0, 5); CloseBtn.Text = "X"; CloseBtn.BackgroundTransparency = 1; CloseBtn.TextColor3 = Color3.new(1,1,1)
    local MinBtn = Instance.new("TextButton", TopBar); MinBtn.Size = UDim2.new(0, 30, 0, 30); MinBtn.Position = UDim2.new(1, -70, 0, 5); MinBtn.Text = "-"; MinBtn.BackgroundTransparency = 1; MinBtn.TextColor3 = Color3.new(1,1,1)
    
    local TabContent = Instance.new("Frame", Main); TabContent.Size = UDim2.new(1, 0, 1, -40); TabContent.Position = UDim2.new(0, 0, 0, 40); TabContent.BackgroundTransparency = 1
    CloseBtn.MouseButton1Click:Connect(function() UI:Destroy() end)
    local minimized = false
    MinBtn.MouseButton1Click:Connect(function() minimized = not minimized; TweenService:Create(Main, TweenInfo.new(0.3), {Size = minimized and UDim2.new(0, 500, 0, 40) or UDim2.new(0, 500, 0, 300)}):Play(); TabContent.Visible = not minimized end)

    local drag, dragStart, startPos
    TopBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; dragStart = i.Position; startPos = Main.Position end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - dragStart; Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)

    local Sidebar = Instance.new("Frame", TabContent); Sidebar.Size = UDim2.new(0, 130, 1, 0); Sidebar.BackgroundTransparency = 1
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5); Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 5)
    local Content = Instance.new("Frame", TabContent); Content.Position = UDim2.new(0, 140, 0, 0); Content.Size = UDim2.new(1, -150, 1, 0); Content.BackgroundTransparency = 1
    
    local Window = {TopBar = TopBar}; local first = true

    function Window:CreateTab(name)
        local btn = Instance.new("TextButton", Sidebar); btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Text = name; btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; Instance.new("UICorner", btn)
        local TabFrame = Instance.new("ScrollingFrame", Content); TabFrame.Size = UDim2.new(1, 0, 1, 0); TabFrame.BackgroundTransparency = 1; TabFrame.ScrollBarThickness = 2; TabFrame.Visible = false; TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Instance.new("UIListLayout", TabFrame).Padding = UDim.new(0, 10); Instance.new("UIPadding", TabFrame).PaddingLeft = UDim.new(0, 5)
        if first then TabFrame.Visible = true; first = false end
        btn.MouseButton1Click:Connect(function() for _,v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end; TabFrame.Visible = true end)
        local TabObj = {}
        function TabObj:AddButton(t, cb) local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = t; b.BackgroundColor3 = Color3.fromRGB(50, 50, 50); Instance.new("UICorner", b); b.MouseButton1Click:Connect(cb) end
        function TabObj:AddToggle(t, cb) local s = false; local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = t; b.BackgroundColor3 = Color3.fromRGB(50, 50, 50); Instance.new("UICorner", b); b.MouseButton1Click:Connect(function() s = not s; b.BackgroundColor3 = s and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(50, 50, 50); cb(s) end) end
        function TabObj:AddDropdown(n, l, cb)
            local d = Instance.new("TextButton", TabFrame); d.Size = UDim2.new(0.95, 0, 0, 40); d.Text = n .. " [v]"; d.BackgroundColor3 = Color3.fromRGB(50, 50, 50); Instance.new("UICorner", d)
            local lh = Instance.new("Frame", TabFrame); lh.Size = UDim2.new(0.95, 0, 0, #l * 35); lh.BackgroundColor3 = Color3.fromRGB(40, 40, 40); lh.Visible = false; Instance.new("UIListLayout", lh); Instance.new("UICorner", lh)
            local open = false; d.MouseButton1Click:Connect(function() open = not open; lh.Visible = open; d.Text = n .. (open and " [^]" or " [v]") end)
            for _, i in pairs(l) do local o = Instance.new("TextButton", lh); o.Size = UDim2.new(1, 0, 0, 35); o.Text = i; o.BackgroundTransparency = 1; o.MouseButton1Click:Connect(function() open=false; lh.Visible=false; d.Text=n..": "..i; cb(i) end) end
        end
        function TabObj:AddSlider(n, min, max, cb)
            local s = Instance.new("Frame", TabFrame); s.Size = UDim2.new(0.95, 0, 0, 45); s.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Instance.new("UICorner", s)
            local l = Instance.new("TextLabel", s); l.Size = UDim2.new(1,0,0.5,0); l.Text = n..": "..min; l.BackgroundTransparency = 1; local b = Instance.new("Frame", s); b.Size = UDim2.new(0.9, 0, 0, 6); b.Position = UDim2.new(0.05, 0, 0.6, 0); b.BackgroundColor3 = Color3.fromRGB(60, 60, 60); Instance.new("UICorner", b)
            local f = Instance.new("Frame", b); f.Size = UDim2.new(0,0,1,0); f.BackgroundColor3 = Color3.fromRGB(0, 150, 255); Instance.new("UICorner", f)
            b.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then local c; c = UserInputService.InputChanged:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseMovement then local p = math.clamp((inp.Position.X - b.AbsolutePosition.X)/b.AbsoluteSize.X, 0, 1); f.Size = UDim2.new(p,0,1,0); local v = math.floor(min + (max-min)*p); l.Text = n..": "..v; cb(v) end end); UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then c:Disconnect() end end) end end)
        end
        function TabObj:AddColorPicker(n, default, cb)
            local current = default
            local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = n; b.BackgroundColor3 = current; Instance.new("UICorner", b)
            local d = Instance.new("Frame", UI); d.Size = UDim2.new(0, 150, 0, 100); d.Position = UDim2.new(0, 10, 0, 10); d.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", d)
            local colorBox = Instance.new("Frame", d); colorBox.Size = UDim2.new(0, 40, 0, 40); colorBox.Position = UDim2.new(0, 5, 0, 5); colorBox.BackgroundColor3 = current
            local info = Instance.new("TextLabel", d); info.Position = UDim2.new(0, 50, 0, 5); info.Size = UDim2.new(0, 95, 0, 40); info.TextScaled = true; info.BackgroundTransparency = 1; info.TextColor3 = Color3.new(1,1,1)
            local p = Instance.new("ImageButton", TabFrame); p.Size = UDim2.new(0.95, 0, 0, 150); p.Image = "rbxassetid://4155801252"; p.Visible = false; Instance.new("UICorner", p)
            b.MouseButton1Click:Connect(function() p.Visible = not p.Visible end)
            p.MouseButton1Click:Connect(function(x, y)
                local relX = (x - p.AbsolutePosition.X) / p.AbsoluteSize.X
                local relY = (y - p.AbsolutePosition.Y) / p.AbsoluteSize.Y
                current = Color3.fromHSV(relX, 1 - relY, 1)
                b.BackgroundColor3 = current; colorBox.BackgroundColor3 = current
                info.Text = "R:"..math.floor(current.R*255).." G:"..math.floor(current.G*255).." B:"..math.floor(current.B*255)
                cb(current)
            end)
        end
        return TabObj
    end
    UserInputService.InputBegan:Connect(function(i) if i.KeyCode == Enum.KeyCode.RightControl then UI.Enabled = not UI.Enabled end end)
    return Window
end

Library.Construct = BuildUI
return Library
