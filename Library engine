local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local LocalizationService = game:GetService("LocalizationService")

local function _T(text)
    local success, translator = pcall(function()
        return LocalizationService:GetTranslatorForLocaleAsync(LocalizationService.RobloxLocaleId)
    end)
    if success and translator then
        local translation = translator:Translate(game, text)
        return translation or text
    end
    return text
end

local function BuildUI(title, theme)
    local ExistingUI = CoreGui:FindFirstChild("GSHUBLIB")
    if ExistingUI then ExistingUI:Destroy() end

    local UI = Instance.new("ScreenGui", CoreGui); UI.Name = "GSHUBLIB"
    local Main = Instance.new("Frame", UI); Main.Size = UDim2.new(0, 500, 0, 350); Main.Position = UDim2.new(0.5, -250, 0.5, -175); Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", Main)
    local stroke = Instance.new("UIStroke", Main); stroke.Color = Color3.new(1,1,1); stroke.Thickness = 2
    
    local TopBar = Instance.new("Frame", Main); TopBar.Size = UDim2.new(1, 0, 0, 40); TopBar.BackgroundTransparency = 1
    local Txt = Instance.new("TextLabel", TopBar); Txt.Size = UDim2.new(1, -100, 1, 0); Txt.Position = UDim2.new(0, 10, 0, 0); Txt.Text = title; Txt.TextColor3 = Color3.new(1,1,1); Txt.Font = Enum.Font.GothamBold; Txt.TextSize = 16; Txt.BackgroundTransparency = 1; Txt.TextXAlignment = Enum.TextXAlignment.Left

    local dragging, dragStart, startPos = false, nil, nil

    local function update(input)
        local delta = input.Position - dragStart
        local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        TweenService:Create(Main, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = newPos}):Play()
    end

    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = Main.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)

    local CloseBtn = Instance.new("TextButton", TopBar); CloseBtn.Size = UDim2.new(0, 25, 0, 25); CloseBtn.Position = UDim2.new(1, -35, 0, 7); CloseBtn.Text = "X"; CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50); Instance.new("UICorner", CloseBtn); CloseBtn.MouseButton1Click:Connect(function() UI:Destroy() end)
    local MinBtn = Instance.new("TextButton", TopBar); MinBtn.Size = UDim2.new(0, 25, 0, 25); MinBtn.Position = UDim2.new(1, -65, 0, 7); MinBtn.Text = "-"; MinBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80); Instance.new("UICorner", MinBtn); MinBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
    
    local TabContent = Instance.new("Frame", Main); TabContent.Size = UDim2.new(1, 0, 1, -40); TabContent.Position = UDim2.new(0, 0, 0, 40); TabContent.BackgroundTransparency = 1
    local Sidebar = Instance.new("ScrollingFrame", TabContent); Sidebar.Size = UDim2.new(0, 130, 1, 0); Sidebar.BackgroundTransparency = 1; Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)
    local Content = Instance.new("Frame", TabContent); Content.Position = UDim2.new(0, 140, 0, 0); Content.Size = UDim2.new(1, -150, 1, 0); Content.BackgroundTransparency = 1

    local Window = {}
    
    function Window:Notify(t, d, IsButtonsEnabled, buttons)
        local NotifyHolder = Instance.new("Frame", UI)
        NotifyHolder.Name = "NotifyHolder"; NotifyHolder.Size = UDim2.new(0, 260, 1, -20); NotifyHolder.Position = UDim2.new(1, -270, 0, 10); NotifyHolder.BackgroundTransparency = 1; Instance.new("UIListLayout", NotifyHolder).Padding = UDim.new(0, 10)
        local lbl = Instance.new("TextLabel", NotifyHolder); lbl.Size = UDim2.new(1,0,0,30); lbl.Text = _T(t); lbl.TextColor3 = Color3.new(1,1,1); lbl.BackgroundTransparency = 1
        local Desc = Instance.new("TextLabel", NotifyHolder); Desc.Size = UDim2.new(1,0,0,30); Desc.Text = _T(d); Desc.TextColor3 = Color3.new(0.8,0.8,0.8); Desc.BackgroundTransparency = 1
        
        if IsButtonsEnabled and buttons then
            for name, callback in pairs(buttons) do
                local btn = Instance.new("TextButton", NotifyHolder); btn.Size = UDim2.new(0.4, 0, 0, 30); btn.Text = _T(name); btn.BackgroundColor3 = Color3.fromRGB(0, 100, 255); btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", btn); btn.MouseButton1Click:Connect(function() callback(); NotifyHolder:Destroy() end)
            end
        else
            task.wait(3); NotifyHolder:Destroy()
        end
    end

    function Window:CreateTab(name)
        local btn = Instance.new("TextButton", Sidebar); btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Text = name; btn.TextColor3 = Color3.new(1,1,1); btn.BackgroundColor3 = Color3.fromRGB(40,40,40); Instance.new("UICorner", btn); btn.Font = Enum.Font.Gotham; btn.TextSize = 13
        local TabFrame = Instance.new("ScrollingFrame", Content); TabFrame.Size = UDim2.new(1, 0, 1, 0); TabFrame.BackgroundTransparency = 1; TabFrame.Visible = false; Instance.new("UIListLayout", TabFrame).Padding = UDim.new(0, 8)
        btn.MouseButton1Click:Connect(function() for _,v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end; TabFrame.Visible = true end)
        
        local TabObj = {}
        local function AddIndicator(name, parent)
            local ind = Instance.new("TextLabel", parent); ind.Size = UDim2.new(1, -10, 0, 10); ind.Text = name; ind.TextColor3 = Color3.fromRGB(150, 150, 150); ind.TextSize = 10; ind.Font = Enum.Font.Gotham; ind.BackgroundTransparency = 1; ind.TextXAlignment = Enum.TextXAlignment.Right
        end

        function TabObj:AddButton(t, cb)
            AddIndicator("Button", TabFrame); local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 40); b.Text = _T(t); b.TextColor3 = Color3.new(1,1,1); b.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", b); b.MouseButton1Click:Connect(cb)
        end
        function TabObj:AddToggle(t, cb)
            AddIndicator("Toggle", TabFrame); local s = false; local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 40); b.Text = _T(t); b.TextColor3 = Color3.new(1,1,1); b.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", b); b.MouseButton1Click:Connect(function() s = not s; b.BackgroundColor3 = s and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(30,30,30); cb(s) end)
        end
        function TabObj:AddSlider(n, min, max, cb)
            AddIndicator("Slider", TabFrame); local s = Instance.new("Frame", TabFrame); s.Size = UDim2.new(0.9, 0, 0, 50); s.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", s); local bar = Instance.new("Frame", s); bar.Size = UDim2.new(0, 0, 1, 0); bar.BackgroundColor3 = Color3.fromRGB(0, 100, 255); Instance.new("UICorner", bar); local l = Instance.new("TextLabel", s); l.Size = UDim2.new(1,0,1,0); l.Text = _T(n); l.TextColor3 = Color3.new(1,1,1); l.BackgroundTransparency = 1; s.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then local c; c = UserInputService.InputChanged:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then local p = math.clamp((inp.Position.X - s.AbsolutePosition.X)/s.AbsoluteSize.X, 0, 1); bar.Size = UDim2.new(p, 0, 1, 0); local v = math.floor(min + (max-min)*p); l.Text = _T(n)..": "..v; cb(v) end end); UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then c:Disconnect() end end) end end)
        end
        function TabObj:AddTextBox(title, placeholder, cb)
            AddIndicator("TextBox", TabFrame); local tLabel = Instance.new("TextLabel", TabFrame); tLabel.Text = title; tLabel.TextColor3 = Color3.new(1,1,1); tLabel.BackgroundTransparency = 1; tLabel.Size = UDim2.new(0.9, 0, 0, 20); local t = Instance.new("TextBox", TabFrame); t.Size = UDim2.new(0.9, 0, 0, 40); t.PlaceholderText = _T(placeholder); t.Text = ""; t.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", t); t.FocusLost:Connect(function() cb(t.Text) end)
        end
        function TabObj:AddColorSelection(n, default, cb)
            AddIndicator("ColorPicker", TabFrame); local s = Instance.new("Frame", TabFrame); s.Size = UDim2.new(0.9, 0, 0, 40); s.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", s); local cp = Instance.new("ImageButton", s); cp.Size = UDim2.new(0, 30, 0, 30); cp.Position = UDim2.new(0.85, 0, 0.15, 0); cp.BackgroundColor3 = default; Instance.new("UICorner", cp); local palette = Instance.new("ImageLabel", s); palette.Size = UDim2.new(0, 100, 0, 100); palette.Position = UDim2.new(1, 10, 0, 0); palette.Image = "rbxassetid://147759600"; palette.Visible = false; cp.MouseButton1Click:Connect(function() palette.Visible = not palette.Visible end); palette.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local color = palette:GetPixel(i.Position.X - palette.AbsolutePosition.X, i.Position.Y - palette.AbsolutePosition.Y); cp.BackgroundColor3 = color; cb(color); palette.Visible = false end end)
        end
        return TabObj
    end
    return Window
end

Library.Construct = BuildUI
return Library
