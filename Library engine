local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local function _T(t) return t end

local function BuildUI(title)
    local ExistingUI = CoreGui:FindFirstChild("GSHUBLIB")
    if ExistingUI then ExistingUI:Destroy() end

    local UI = Instance.new("ScreenGui", CoreGui); UI.Name = "GSHUBLIB"
    local NotifyHolder = Instance.new("Frame", UI)
    NotifyHolder.Name = "NotifyHolder"; NotifyHolder.Size = UDim2.new(0, 260, 1, -20); NotifyHolder.Position = UDim2.new(1, -270, 0, 10); NotifyHolder.BackgroundTransparency = 1
    Instance.new("UIListLayout", NotifyHolder).Padding = UDim.new(0, 10)

    local Main = Instance.new("Frame", UI); Main.Size = UDim2.new(0, 500, 0, 350); Main.Position = UDim2.new(0.5, -250, 0.5, -175); Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Instance.new("UICorner", Main)
    Instance.new("UIStroke", Main).Color = Color3.new(1,1,1); Instance.new("UIStroke", Main).Thickness = 2
    
    local TopBar = Instance.new("Frame", Main); TopBar.Size = UDim2.new(1, 0, 0, 40); TopBar.BackgroundTransparency = 1
    local Txt = Instance.new("TextLabel", TopBar); Txt.Size = UDim2.new(1, -100, 1, 0); Txt.Position = UDim2.new(0, 10, 0, 0); Txt.Text = title; Txt.TextColor3 = Color3.new(1,1,1); Txt.Font = Enum.Font.GothamBold; Txt.TextSize = 16; Txt.BackgroundTransparency = 1; Txt.TextXAlignment = Enum.TextXAlignment.Left

    local dragging, dragStart, startPos = false, nil, nil
    TopBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = input.Position; startPos = Main.Position end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then local delta = input.Position - dragStart; Main.Position = startPos + UDim2.new(0, delta.X, 0, delta.Y) end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    local TabContent = Instance.new("Frame", Main); TabContent.Size = UDim2.new(1, 0, 1, -40); TabContent.Position = UDim2.new(0, 0, 0, 40); TabContent.BackgroundTransparency = 1
    local Sidebar = Instance.new("ScrollingFrame", TabContent); Sidebar.Size = UDim2.new(0, 130, 1, 0); Sidebar.BackgroundTransparency = 1; Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)
    local Content = Instance.new("Frame", TabContent); Content.Position = UDim2.new(0, 140, 0, 0); Content.Size = UDim2.new(1, -150, 1, 0); Content.BackgroundTransparency = 1

    local Window = {}
    function Window:Notify(t, d, IsButtonsEnabled, buttons)
        local N = Instance.new("Frame", NotifyHolder); N.Size = UDim2.new(1, 0, 0, 80); N.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Instance.new("UICorner", N); Instance.new("UIStroke", N).Color = Color3.new(1,1,1)
        Instance.new("TextLabel", N, {Size=UDim2.new(1,0,0,30), Text=t, TextColor3=Color3.new(1,1,1), BackgroundTransparency=1})
        Instance.new("TextLabel", N, {Size=UDim2.new(1,0,0,30), Position=UDim2.new(0,0,0,30), Text=d, TextColor3=Color3.new(0.8,0.8,0.8), BackgroundTransparency=1})
        if IsButtonsEnabled and buttons then for n, cb in pairs(buttons) do local b = Instance.new("TextButton", N); b.Size = UDim2.new(0.8, 0, 0, 20); b.Text = n; b.MouseButton1Click:Connect(function() cb(); N:Destroy() end) end else task.wait(3); N:Destroy() end
    end

    function Window:CreateTab(name)
        local btn = Instance.new("TextButton", Sidebar); btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Text = name; btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
        local TabFrame = Instance.new("ScrollingFrame", Content); TabFrame.Size = UDim2.new(1, 0, 1, 0); TabFrame.BackgroundTransparency = 1; TabFrame.Visible = false; Instance.new("UIListLayout", TabFrame).Padding = UDim.new(0, 8)
        btn.MouseButton1Click:Connect(function() for _,v in pairs(Content:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end; TabFrame.Visible = true end)
        
        local TabObj = {}
        local function AddInd(txt, p) local i = Instance.new("TextLabel", p); i.Size = UDim2.new(0, 60, 1, 0); i.Position = UDim2.new(1, -65, 0, 0); i.Text = txt; i.TextColor3 = Color3.fromRGB(150,150,150); i.TextSize = 10; i.BackgroundTransparency = 1; i.TextXAlignment = Enum.TextXAlignment.Right end

        function TabObj:AddButton(t, cb) local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 35); b.Text = _T(t); b.BackgroundColor3 = Color3.fromRGB(30,30,30); AddInd("Button", b); b.MouseButton1Click:Connect(cb) end
        function TabObj:AddToggle(t, cb) local s = false; local b = Instance.new("TextButton", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 35); b.Text = _T(t); b.BackgroundColor3 = Color3.fromRGB(30,30,30); AddInd("Toggle", b); b.MouseButton1Click:Connect(function() s = not s; b.BackgroundColor3 = s and Color3.fromRGB(0,100,255) or Color3.fromRGB(30,30,30); cb(s) end) end
        function TabObj:AddSlider(n, min, max, cb) local s = Instance.new("Frame", TabFrame); s.Size = UDim2.new(0.9, 0, 0, 35); s.BackgroundColor3 = Color3.fromRGB(30,30,30); AddInd("Slider", s); local bar = Instance.new("Frame", s); bar.Size = UDim2.new(0, 0, 1, 0); bar.BackgroundColor3 = Color3.fromRGB(0,100,255); s.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then local c; c = UserInputService.InputChanged:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseMovement then local p = math.clamp((inp.Position.X - s.AbsolutePosition.X)/s.AbsoluteSize.X, 0, 1); bar.Size = UDim2.new(p, 0, 1, 0); cb(math.floor(min + (max-min)*p)) end end); UserInputService.InputEnded:Connect(function() c:Disconnect() end) end end) end
        function TabObj:AddTextBox(t, p, opt, cb) local b = Instance.new("TextBox", TabFrame); b.Size = UDim2.new(0.9, 0, 0, 35); b.PlaceholderText = _T(p); b.BackgroundColor3 = Color3.fromRGB(30,30,30); AddInd("TextBox", b); b.FocusLost:Connect(function() (type(opt) == "function" and opt or cb)(b.Text) end) end
        function TabObj:AddColorSelection(n, default, cb) local s = Instance.new("Frame", TabFrame); s.Size = UDim2.new(0.9, 0, 0, 35); s.BackgroundColor3 = Color3.fromRGB(30,30,30); AddInd("Color", s); local cp = Instance.new("ImageButton", s); cp.Size = UDim2.new(0, 25, 0, 25); cp.Position = UDim2.new(0, 5, 0.1, 0); cp.BackgroundColor3 = default; local pal = Instance.new("ImageLabel", s); pal.Size = UDim2.new(0, 100, 0, 100); pal.Position = UDim2.new(1, 10, 0, 0); pal.Image = "rbxassetid://18967417561"; pal.Visible = false; cp.MouseButton1Click:Connect(function() pal.Visible = not pal.Visible end); pal.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local color = pal:GetPixel(i.Position.X - pal.AbsolutePosition.X, i.Position.Y - pal.AbsolutePosition.Y); cp.BackgroundColor3 = color; cb(color) end end) end
        
        return TabObj
    end
    return Window
end

Library.Construct = BuildUI
return Library
