local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Library = {}

function Library:Init(title)
    local UI = Instance.new("ScreenGui", CoreGui)
    UI.Name = "GalaxyLib"

    -- Main Frame (Deitado e moderno)
    local Main = Instance.new("Frame", UI)
    Main.Size = UDim2.new(0, 500, 0, 300)
    Main.Position = UDim2.new(0.5, -250, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
    Instance.new("UIStroke", Main).Thickness = 2
    Main.UIStroke.Color = Color3.fromRGB(50, 50, 50)

    -- Sidebar (Onde ficam as Tabs)
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 120, 1, 0)
    Sidebar.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0, 10)
    
    local TabContainer = Instance.new("UIListLayout", Sidebar)
    TabContainer.Padding = UDim.new(0, 5)
    TabContainer.HorizontalAlignment = Enum.HorizontalAlignment.Center

    -- Container de conteúdo (Onde os botões aparecem)
    local Content = Instance.new("Frame", Main)
    Content.Position = UDim2.new(0, 130, 0, 10)
    Content.Size = UDim2.new(1, -140, 1, -20)
    Content.BackgroundTransparency = 1

    local Window = {}
    
    function Window:CreateTab(name)
        local btn = Instance.new("TextButton", Sidebar)
        btn.Size = UDim2.new(0.9, 0, 0, 40)
        btn.Text = name
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Instance.new("UICorner", btn)
        
        -- Aqui dentro você criaria a lógica de trocar o Container ativo
        -- Por enquanto, vamos manter a estrutura básica
        return btn
    end

    return Window
end

return Library
